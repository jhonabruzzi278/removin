# Backend API Environment Variables - EXAMPLE FILE
# Copia este archivo a .env y completa con tus credenciales reales

# Puerto del servidor
PORT=3001

# Node Environment (development/production)
NODE_ENV=development

# Frontend URL (para CORS en producción)
FRONTEND_URL=https://tu-app.vercel.app

# Firebase Admin SDK (para acceder a Realtime Database)
# Obtén estos valores de: Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Sentry Error Monitoring (Opcional - Backend)
# Obtén el DSN de: https://sentry.io/settings/projects/your-project/keys/
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# NOTA: Los tokens de Replicate son gestionados por cada usuario.
# Cada usuario configura su propio token desde la app (Onboarding).
# El backend recupera el token del usuario desde Firebase Realtime DB.
