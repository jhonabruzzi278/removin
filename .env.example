# ========================================
# REMOVIN - Variables de Entorno (FRONTEND)
# ========================================
# Copia este archivo como .env.local y completa los valores

# ----------------------------------------
# Firebase Configuration (Cliente Web)
# ----------------------------------------
# Obtén estos valores de: https://console.firebase.google.com/project/_/settings/general
# En "Your apps" > Configuración de tu Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Backend API URL (solo desarrollo local, en producción usa el mismo dominio)
VITE_API_URL=http://localhost:3001

# ----------------------------------------
# Sentry Error Monitoring (Opcional)
# ----------------------------------------
# Obtén el DSN de: https://sentry.io/settings/projects/your-project/keys/
# Crear proyecto en Sentry: https://sentry.io/signup/
VITE_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# Instructions:
# 1. Copy this file to .env.local
# 2. Go to https://console.firebase.google.com
# 3. Create a new project or select existing one
# 4. Go to Project Settings > General (for frontend variables)
# 5. Go to Project Settings > Service Accounts (for backend variables)
# 6. Enable Authentication > Sign-in method > Google
# 7. Enable Firestore Database
# 8. Enable Storage
# 9. Never commit .env.local to version control
